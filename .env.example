# ─────────────────────────────────────────────────────────
# Real-Time Customer Transaction Analytics Pipeline
# Copy to .env and adjust values for your environment
# ─────────────────────────────────────────────────────────

# ── Kafka ────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=transactions
KAFKA_ENRICHED_TOPIC=transactions_enriched
KAFKA_ANOMALY_TOPIC=anomalies
KAFKA_DAILY_SPEND_TOPIC=daily_spend

# ── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017
MONGO_DB=txn_analytics
MONGO_TXN_COLLECTION=transactions
MONGO_ANOMALY_COLLECTION=anomalies
MONGO_DAILY_SPEND_COLLECTION=daily_spend

# ── Producer ─────────────────────────────────────────────
TARGET_TPS=1000
BATCH_SIZE=500
NUM_USERS=5000
NUM_MERCHANTS=200

# ── Consumers ────────────────────────────────────────────
MONGO_CONSUMER_GROUP=mongo-sink
DAILY_SPEND_CONSUMER_GROUP=daily-spend-sink
SINK_BATCH_SIZE=500

# ── Dashboard ────────────────────────────────────────────
DASHBOARD_REFRESH_SECS=30

# ── dbt / Export ─────────────────────────────────────────
EXPORT_DIR=dbt_models/seeds/raw
EXPORT_LOOKBACK=90

# ── Airflow ──────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
AIRFLOW__CORE__LOAD_EXAMPLES=false

# ── General ──────────────────────────────────────────────
LOG_LEVEL=INFO
